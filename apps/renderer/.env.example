# ============================================================
# CLAIRE — Variables d'environnement (Next.js / Vercel)
# ============================================================
# Copier ce fichier en .env.local pour le dev local
# Toutes ces variables doivent être configurées dans Vercel
# ============================================================


# ── Firebase (client-side) ───────────────────────────────────
# Console Firebase → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=          # ex: mon-projet.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=           # ex: mon-projet-12345
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=       # ex: mon-projet.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=


# ── Firebase Admin (server-side) ─────────────────────────────
# Console Firebase → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=                       # même que NEXT_PUBLIC_FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=                     # ex: firebase-adminsdk-xxxx@mon-projet.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=                      # clé PEM complète entre guillemets, \n pour les sauts de ligne


# ── Stripe ───────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=        # pk_live_... (ou pk_test_... en dev)
STRIPE_SECRET_KEY=                         # sk_live_... (ou sk_test_... en dev)

# dashboard.stripe.com → Developers → Webhooks → ton endpoint
STRIPE_WEBHOOK_SECRET=                     # whsec_...

# dashboard.stripe.com → Products → copier les Price IDs
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=       # price_...
NEXT_PUBLIC_STRIPE_ANNUAL_PRICE_ID=        # price_...
NEXT_PUBLIC_STRIPE_MAX_MONTHLY_PRICE_ID=   # price_... (plan Max mensuel)
NEXT_PUBLIC_STRIPE_MAX_ANNUAL_PRICE_ID=    # price_... (plan Max annuel)
STRIPE_MAX_MONTHLY_PRICE_ID=              # même que NEXT_PUBLIC (utilisé côté serveur)
STRIPE_MAX_ANNUAL_PRICE_ID=              # même que NEXT_PUBLIC (utilisé côté serveur)
STRIPE_ENTERPRISE_PRICE_ID=              # price_... (plan Enterprise)


# ── Backend Railway ───────────────────────────────────────────
# URL du service Railway (backend Node.js)
API_URL=                                   # ex: https://claire-web-production.up.railway.app
APP_WEB_URL=                               # ex: https://app.clairia.app


# ── Sécurité ─────────────────────────────────────────────────
# Clé aléatoire pour chiffrer les credentials OAuth stockés
# Générer: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# Secret pour protéger les routes cron (doit correspondre côté Railway)
CRON_SECRET=


# ── LLM (suggestions contextuelles) ──────────────────────────
# Utilisé pour générer les suggestions après chaque réponse Ask
OPENAI_API_KEY=                            # sk-proj-...

# Recall.ai Desktop SDK (server-side only)
RECALL_API_KEY=                            # recall_...
RECALL_API_URL=https://us-west-2.recall.ai # Region base URL

# Product analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=                   # phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=                           # optional server-side key; falls back to NEXT_PUBLIC_POSTHOG_KEY
POSTHOG_HOST=https://us.i.posthog.com

# RevenueCat Web Billing
NEXT_PUBLIC_REVENUECAT_API_KEY=            # rcb_live_... or rcb_sb_... public Web Billing SDK key
NEXT_PUBLIC_REVENUECAT_PRO_ENTITLEMENT_ID=pro
REVENUECAT_SECRET_API_KEY=                 # sk_... server-side REST key, optional for /api/revenuecat/status
REVENUECAT_API_URL=https://api.revenuecat.com/v1


# ── Email (Resend) ──────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=                            # re_...


# ── Sentry (monitoring erreurs) ───────────────────────────────
# sentry.io → Settings → Projects → claire-web → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=                    # https://xxx@oyyy.ingest.sentry.io/zzz
